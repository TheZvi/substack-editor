{
  "manifest_version": 3,
  "name": "Substack TOC Helper",
  "version": "1.1",
  "description": "Automatically create or correct a Table of Contents for Substack posts and crosspost to WordPress.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs",
    "tabGroups",
    "contextMenus",
    "commands",
    "notifications",
    "webNavigation",
    "identity",
    "sessions"
  ],
  "oauth2": {
    "client_id": "633231389022-1g8alhfppclvipc7ndqllubltkr0ap1b.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/documents",
      "https://www.googleapis.com/auth/drive"
    ]
  },
  "host_permissions": [
    "https://*.wordpress.com/*",
    "https://*.substack.com/publish/post/*",
    "https://api.anthropic.com/*",
    "https://*.anthropic.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://x.com/*",
    "https://*.x.com/*",
    "https://pro.x.com/*",
    "https://substackcdn.com/*",
    "https://*.substackcdn.com/*",
    "https://docs.google.com/*",
    "https://www.googleapis.com/*",
    "https://oauth2.googleapis.com/*"
  ],
  "commands": {        
    "transform-text": {
      "suggested_key": {
        "default": "Ctrl+Q"
      },
      "description": "Transform selected text"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*.substack.com/publish/post/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["https://*.wordpress.com/wp-admin/post-new.php*"],
      "js": ["receivers/wordpress-receiver.js"]
    },
    {
      "matches": ["https://x.com/compose/articles*", "https://x.com/compose/articles/*", "https://x.com/compose/articles/edit/*"],
      "js": ["receivers/twitter-receiver.js"],
      "all_frames": true,
      "run_at": "document_idle"
    },
    {
      "matches": ["https://x.com/*", "https://twitter.com/*", "https://pro.x.com/*"],
      "js": ["twitter/twitter-shortcuts.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://docs.google.com/document/*"],
      "js": ["receivers/googledoc-receiver.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "exclude_matches": [
        "https://x.com/*",
        "https://twitter.com/*",
        "https://pro.x.com/*",
        "https://*.substack.com/publish/post/*"
      ],
      "js": ["universal/quote-copy.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [{
    "resources": [
      "extractContents.js",
      "formatters/wordpress-formatter.js",
      "formatters/twitter-formatter.js",
      "receivers/wordpress-receiver.js",
      "receivers/twitter-receiver.js",
      "receivers/twitter-newline-fixer.js",
      "receivers/googledoc-receiver.js",
      "twitter/twitter-list-sync.js",
      "twitter/twitter-shortcuts.js",
      "linkify/default-rules.json",
      "linkify/linkify-controller.js",
      "linkify/ui/manage-linkify-rules.html",
      "linkify/ui/manage-linkify-rules.js",
      "linkify/ui/manage-linkify-rules.css",
      "shared/llm/api/base-api.js",
      "shared/llm/api/gemini_api.js",
      "shared/llm/api/claude_api.js",
      "shared/llm/config/api-keys.local.js",
      "shared/llm/config/*",
      "features/text-transform/*",
      "shared/llm/api/default-rules.json",
      "shared/google/googledocs-api.js",
      "shared/google/googledocs-review.js",
      "universal/quote-copy.js",
      "author-annotations/ui/manage-annotations.html",
      "author-annotations/ui/manage-annotations.js",
      "author-annotations/ui/manage-annotations.css"
    ],
    "matches": ["<all_urls>"]
  }],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "options_page": "options/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}